@prefix : <http://arangodb.com/schema/hybrid#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix phys: <http://arangodb.com/schema/physical#> .

: a owl:Ontology ;
  rdfs:label "Conceptual Schema" ;
  rdfs:comment "Conceptual schema inferred from ArangoDB physical schema." .

phys:mappingStyle a owl:AnnotationProperty .
phys:collectionName a owl:AnnotationProperty .
phys:typeField a owl:AnnotationProperty .
phys:typeValue a owl:AnnotationProperty .
phys:edgeCollectionName a owl:AnnotationProperty .

:Doc a owl:Class ;
  rdfs:label "Doc" .
:Doc phys:mappingStyle "COLLECTION" .
:Doc phys:collectionName "docs" .

:Person a owl:Class ;
  rdfs:label "Person" .
:Person phys:mappingStyle "COLLECTION" .
:Person phys:collectionName "persons" .

:Place a owl:Class ;
  rdfs:label "Place" .
:Place phys:mappingStyle "COLLECTION" .
:Place phys:collectionName "places" .

:User a owl:Class ;
  rdfs:label "User" .
:User phys:mappingStyle "COLLECTION" .
:User phys:collectionName "users" .

:FOLLOWS a owl:ObjectProperty ;
  rdfs:label "FOLLOWS" ;
  rdfs:domain :Any ;
  rdfs:range :Any  .
:FOLLOWS phys:mappingStyle "DEDICATED_COLLECTION" .
:FOLLOWS phys:edgeCollectionName "follows" .
