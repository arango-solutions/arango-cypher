# ─── ArangoDB Connection ─────────────────────────────────────────────
# URL of the ArangoDB coordinator (http or https)
ARANGO_URL=http://localhost:8529
# ARANGO_URL=https://your-instance.arangocloud.com/

# Default database to connect to
ARANGO_DB=_system

# Credentials. Both the FastAPI service and the `arango-cypher` CLI read
# ARANGO_PASSWORD as the canonical name (matches industry convention —
# Postgres, Redis, MongoDB, MySQL, Cassandra all use *_PASSWORD). The
# legacy ARANGO_PASS name is still accepted as a deprecated fallback and
# logs a one-time warning per process; it will be removed at the next
# major release. Set ARANGO_PASSWORD; remove ARANGO_PASS from your env.
# CLI also accepts legacy ARANGO_HOST / ARANGO_PORT / ARANGO_PROTOCOL in
# lieu of ARANGO_URL.
ARANGO_USER=root
ARANGO_PASSWORD=
# ARANGO_PASS=   # DEPRECATED — falls back if ARANGO_PASSWORD is unset; emits warning.

# ─── LLM Providers (for NL→Cypher / NL→AQL) ────────────────────────
# At least one of these is required for natural-language query generation.

# OpenRouter (recommended for multi-model access)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini         # optional model override

# OpenAI (direct)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini                    # optional model override
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional; for Azure / proxies

# Anthropic (direct). Default model is claude-sonnet-4-5; override with
# ANTHROPIC_MODEL if you want e.g. claude-haiku-4-5 for lower cost.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1  # optional; for proxies

# Select which provider get_llm_provider() returns when multiple keys are set.
# One of: openrouter | openai | anthropic. Defaults to the first key found.
# LLM_PROVIDER=openai

# ─── Server ─────────────────────────────────────────────────────────
# Port for the FastAPI backend (default: 8000)
# PORT=8000

# Base path for the FastAPI app when reverse-proxied under a sub-path
# (e.g. behind the ArangoDB platform router). Leave unset in standalone
# dev. Example: ROOT_PATH=/byoc/arango-cypher
# ROOT_PATH=

# ─── Service limits & CORS ──────────────────────────────────────────
# Per-minute token bucket for NL→Cypher / NL→AQL endpoints. Keyed by
# Authorization header (or client IP for anonymous callers). Default 10.
# NL_RATE_LIMIT_PER_MINUTE=10

# Per-minute token bucket for the CPU-bound (non-LLM) endpoints —
# /translate, /validate, /execute*, /explain, /aql-profile, /schema/*,
# /suggest-indexes, /mapping/*-owl, /tools/call. Same client-key as
# the NL bucket, separate token pool. Default 100 (an order of magnitude
# above the LLM bucket per audit-v2 finding #2 sizing).
# COMPUTE_RATE_LIMIT_PER_MINUTE=100

# How long an idle session may live before eviction. After this many
# seconds without activity, the session's python-arango client is
# closed and the token is invalidated (401 on next use). Default 1800.
# SESSION_TTL_SECONDS=1800

# Upper bound on the in-memory session table; oldest-by-last_used is
# evicted when the cap is reached. Default 100. Raise for multi-tenant
# deployments with many concurrent UI users.
# MAX_SESSIONS=100

# Comma-separated list of allowed CORS origins, or `*` for any.
# Combined with ARANGO_CYPHER_CORS_CREDENTIALS the policy is:
#   * `*` (default) → allow_credentials silently forced off (closes
#     the foot-gun where browsers refuse the combo but non-browser
#     callers honour it). A warning is logged at startup.
#   * `*` + ARANGO_CYPHER_CORS_CREDENTIALS=1 → service refuses to start;
#     pin an explicit origin list instead.
#   * Explicit list → allow_credentials=True by default; override with
#     ARANGO_CYPHER_CORS_CREDENTIALS=0 to disable.
# Default: *
# CORS_ALLOWED_ORIGINS=https://workbench.example.com,https://app.example.com
# ARANGO_CYPHER_CORS_CREDENTIALS=1

# Strict / public-deployment mode. When enabled:
#   * `GET /connect/defaults` returns 404 (no leak of host/db/user).
#   * `POST /connect` rejects literal RFC1918 / loopback / link-local
#     URLs unless they appear in ARANGO_CYPHER_CONNECT_ALLOWED_HOSTS.
#   * NL endpoints (/nl2cypher, /nl2aql, /nl-samples), corrections
#     CRUD (/corrections, /nl-corrections), and /connections require
#     a valid session token (X-Arango-Session or Bearer).
#   * Pydantic-422 logs omit the request body to avoid leaking
#     credential fragments under attacker-controlled malformed input.
# Default: unset (single-user / dev defaults).
# ARANGO_CYPHER_PUBLIC_MODE=true

# Opt back in to returning the ARANGO_PASSWORD value from
# `GET /connect/defaults` (useful on a trusted single-user laptop
# where the connect dialog should auto-fill the password). Default:
# unset → password field is returned as the empty string regardless
# of ARANGO_PASSWORD so an anonymous caller cannot pull the password
# straight out of the .env. Ignored entirely in public mode.
# ARANGO_CYPHER_EXPOSE_DEFAULTS_PASSWORD=1

# Comma-separated allowlist of host literals that bypass the
# /connect SSRF guard. Use this to allowlist a private ArangoDB
# coordinator inside a VPC when running in public mode, or to
# explicitly permit a cloud-metadata IP if you really mean to point
# the service at one. Each entry is matched case-insensitively
# against the parsed URL hostname; no DNS resolution happens.
# Default: empty (no overrides).
# ARANGO_CYPHER_CONNECT_ALLOWED_HOSTS=10.0.0.5,db.internal.example.com

# ─── Multi-tenant scope (tenant-aware deployments only) ─────────────
# Regex that marks a property as a tenant-id carrier in the schema
# analyzer's tenant-scope inference. Matches against property names
# across all conceptual entities. See multitenant_prd.md §4.2.
# Default: built-in regex covering `tenant_id`, `tenantId`, `TENANT_ID`,
# and variants. Override only if your schema uses a non-standard name.
# NL2CYPHER_TENANT_FIELD_REGEX=^(tenant|org|customer)_?id$

# ─── Heuristic schema mapping (fallback) ────────────────────────────
# When the arangodb-schema-analyzer package is not available the
# service refuses to start unless this opt-out is set. Intended for
# local exploration only — heuristic mappings miss many edge cases
# that can produce incorrect AQL. Default: unset (refuse).
# ARANGO_CYPHER_ALLOW_HEURISTIC=1

# ─── Schema-analyzer hardening (arangodb-schema-analyzer ≥ 0.6.1) ───
# These are read directly by the upstream arangodb-schema-analyzer
# package; arango-cypher-py forwards no overrides of its own. They
# are documented here because the same .env file is loaded by the
# service entry point and operators expect to discover every knob in
# one place.

# Allowlist of host[:port] values the analyzer is allowed to connect
# to via its `connection.url` parameter. When set, requests targeting
# anything else are rejected before any DB call. Unset preserves the
# trust-the-caller behavior used for local CLI runs.
# SCHEMA_ANALYZER_ALLOWED_HOSTS=arangodb.internal:8529,db.example.com:443

# Containment root for the analyzer's filesystem cache. When set,
# every resolved cache directory must live under this root and `..`
# traversal is rejected. Useful for sandboxed deploys where the cache
# location comes from caller-supplied settings.
# SCHEMA_ANALYZER_CACHE_ROOT=/var/lib/arango-cypher/analyzer-cache

# ─── Dev-only persistence (usually leave unset) ─────────────────────
# On-disk SQLite paths for the rule-learning corrections tables.
# Relative paths resolve from the service's CWD. Default: per-filename
# in CWD. Override to pin a writable location in a sandboxed deploy.
# CORRECTIONS_DB=/var/lib/arango-cypher/corrections.db
# NL_CORRECTIONS_DB=/var/lib/arango-cypher/nl_corrections.db
